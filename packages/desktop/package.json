{
  "name": "@easyagent/desktop",
  "version": "0.6.13",
  "description": "EasyAgent 桌面版 - Electron原生桌面AI编程助手",
  "author": "EasyAgent Team <team@easyagent.dev>",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build:main": "tsup && tsup --config tsup.preload.config.ts",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "dev:main": "tsup --watch",
    "dev:renderer": "vite --port 5183",
    "dev": "concurrently \"npm:dev:main\" \"npm:dev:renderer\"",
    "start": "electron dist/main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "node scripts/postinstall.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.easyagent.desktop",
    "productName": "EasyAgent",
    "npmRebuild": false,
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/.pnpm/**/node_modules/.cache",
      "!node_modules/**/*.ts",
      "!node_modules/**/*.map",
      "!node_modules/**/tsconfig.json",
      "!node_modules/**/.tsbuildinfo",
      "!node_modules/**/__tests__/**",
      "!node_modules/**/test/**",
      "!node_modules/**/tests/**",
      "!node_modules/**/docs/**",
      "!node_modules/**/example/**",
      "!node_modules/**/examples/**",
      "!node_modules/**/.github/**",
      "!node_modules/**/LICENSE",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/README*",
      "!node_modules/**/*.md",
      "!node_modules/**/*.markdown",
      "!node_modules/better-sqlite3/src/**",
      "!node_modules/better-sqlite3/deps/**",
      "!node_modules/better-sqlite3/build/Release/obj/**"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/electron-updater/**",
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**"
    ],
    "extraMetadata": {
      "main": "./dist/main.js"
    },
    "extraResources": [],
    "compression": "maximum",
    "publish": {
      "provider": "github",
      "owner": "ht182400-creator",
      "repo": "easyagent"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "EasyAgent Team"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "EasyAgent",
      "license": "LICENSE",
      "language": "2052",
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "displayLanguageSelector": true,
      "deleteAppDataOnUninstall": false,
      "include": "installer.nsh"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development",
      "maintainer": "EasyAgent Team <team@easyagent.dev>"
    }
  },
  "dependencies": {
    "@easyagent/core": "workspace:*",
    "@easyagent/frontend": "workspace:*",
    "@easyagent/server": "workspace:*",
    "atomic-sleep": "^1.0.0",
    "better-sqlite3": "^12.11.1",
    "bindings": "^1.5.0",
    "body-parser": "^1.20.2",
    "builder-util-runtime": "9.7.0",
    "cors": "^2.8.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "express": "^4.19.0",
    "fast-redact": "^3.1.1",
    "file-uri-to-path": "^2.0.0",
    "fs-extra": "^10.1.0",
    "js-yaml": "^4.1.0",
    "jsonfile": "^6.1.0",
    "lazy-val": "^1.0.5",
    "lodash.escaperegexp": "^4.1.2",
    "lodash.isequal": "^4.5.0",
    "lucide-react": "^0.378.0",
    "mime": "^1.6.0",
    "multer": "^2.2.0",
    "on-exit-leak-free": "^2.1.0",
    "pino": "^9.0.0",
    "pino-abstract-transport": "^1.2.0",
    "pino-std-serializers": "^6.0.0",
    "process-warning": "^3.0.0",
    "quick-format-unescaped": "^4.0.3",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "react-window": "^2.2.7",
    "real-require": "^0.2.0",
    "safe-stable-stringify": "^2.3.1",
    "semver": "~7.7.3",
    "send": "^0.19.0",
    "sonic-boom": "^3.7.0",
    "split2": "^4.2.0",
    "thread-stream": "^2.6.0",
    "tiny-typed-emitter": "^2.1.0",
    "ws": "^8.17.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^15.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "electron": "30.0.0",
    "electron-builder": "23.6.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}
