{
  "_说明": "EasyAgent Desktop 完整运行时依赖清单",
  "_用途": "当使用 pnpm + electron-builder 打包时，所有运行时的 transitive 依赖必须显式声明在 package.json 的 dependencies 中",
  "_更新时间": "2026-06-20",
  "_分类": {
    "express": "Express 框架及其 30 个直接依赖 + 所有孙子依赖",
    "pino": "Pino 日志框架及其子依赖",
    "multer": "文件上传中间件及其子依赖",
    "cors": "跨域中间件及其子依赖",
    "side-channel": "qs 查询字符串解析的子依赖链",
    "electron": "Electron 相关包（electron-store, electron-updater）",
    "better-sqlite3": "原生 SQLite 模块",
    "frontend": "React 前端（已通过 Vite bundle，理论上不需单独声明）",
    "ws": "WebSocket 库"
  },
  "依赖清单": {
    "express": {
      "version": "4.19+",
      "direct_deps": [
        "accepts", "array-flatten", "body-parser", "content-disposition",
        "content-type", "cookie", "cookie-signature", "debug", "depd",
        "encodeurl", "escape-html", "etag", "finalhandler", "fresh",
        "http-errors", "merge-descriptors", "methods", "on-finished",
        "parseurl", "path-to-regexp", "proxy-addr", "qs", "range-parser",
        "safe-buffer", "send", "serve-static", "setprototypeof", "statuses",
        "type-is", "utils-merge", "vary"
      ],
      "grandchild_deps": [
        "negotiator", "mime-types", "mime-db",
        "bytes", "iconv-lite", "raw-body", "unpipe", "destroy",
        "safer-buffer",
        "mime", "ms",
        "forwarded", "ipaddr.js",
        "media-typer",
        "toidentifier", "inherits",
        "ee-first"
      ],
      "qs_side_channel_chain": [
        "side-channel", "side-channel-list", "side-channel-map",
        "side-channel-weakmap", "call-bound", "get-intrinsic",
        "call-bind-apply-helpers", "object-inspect",
        "es-define-property", "es-errors", "es-object-atoms",
        "function-bind", "gopd", "dunder-proto", "get-proto",
        "has-symbols", "hasown", "math-intrinsics"
      ]
    },
    "pino": {
      "version": "9.0+",
      "direct_deps": [
        "atomic-sleep", "fast-redact", "on-exit-leak-free",
        "pino-abstract-transport", "pino-std-serializers",
        "process-warning", "quick-format-unescaped",
        "real-require", "safe-stable-stringify", "sonic-boom",
        "thread-stream"
      ]
    },
    "cors": {
      "version": "2.8+",
      "deps": ["object-assign", "vary"]
    },
    "multer": {
      "version": "2.2+",
      "deps": ["append-field", "busboy", "concat-stream", "type-is"],
      "grandchild_deps": [
        "streamsearch",
        "buffer-from", "readable-stream", "typedarray"
      ]
    },
    "ws": {
      "version": "8.17+",
      "deps": []
    }
  },
