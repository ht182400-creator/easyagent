{
  "name": "@easyagent/server",
  "version": "0.6.5",
  "description": "EasyAgent Web服务端 - REST API + WebSocket",
  "type": "module",
  "main": "./dist/index.js",
  "engines": {
    "node": ">=18.0.0 <24.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "chcp 65001 >nul && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@easyagent/core": "../core",
    "cors": "^2.8.0",
    "express": "^4.19.0",
    "multer": "^2.2.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^2.1.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^1.6.0",
    "supertest": "^7.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
