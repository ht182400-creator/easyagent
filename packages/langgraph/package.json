{
  "name": "@easyagent/langgraph",
  "version": "0.1.0",
  "description": "EasyAgent LangGraph 工作流引擎 — 基于 LangGraph 的状态化智能体",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo": "tsx scripts/run-demo.ts",
    "demo:web": "tsx scripts/demo-server.ts"
  },
  "dependencies": {
    "@easyagent/core": "workspace:*",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "better-sqlite3": "^12.11.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "tsup": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
